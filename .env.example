# development = desarrollo local | production = servidor / IIS
NODE_ENV=development

# --- Base de datos MySQL ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=PortalIssa

# En desarrollo se deja en true: crea BD, tablas y usuario admin automaticamente.
# En produccion ponlo en false una vez que la BD ya exista.
DB_BOOTSTRAP_ENABLED=true

# --- Servidor API ---
PORT=3001
# false en dev (Vite sirve el front). true en produccion sin IIS delante.
SERVE_STATIC_FILES=false
# false en dev. 1 en produccion detras de IIS/proxy.
TRUST_PROXY=false

# --- URLs publicas (solo produccion; dejar vacias en dev) ---
PUBLIC_APP_URL=
PUBLIC_API_URL=
PUBLIC_IP_URL=

# --- Sesiones / cookies ---
SESSION_COOKIE_NAME=portal_issa_sid
SESSION_TTL_DIAS=7
# false en http (dev). true solo si usas https.
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_DOMAIN=

# Origenes permitidos para CORS, separados por coma. Vacio en dev.
CORS_ALLOWED_ORIGINS=

# --- Frontend (Vite) ---
# Vacio = el front usa rutas relativas (/api) que Vite redirige al backend.
VITE_API_BASE_URL=
